# 301 redirects from legacy URLs (old site) to new pages
RewriteEngine On

RewriteRule ^index\.php$ / [R=301,L]
RewriteRule ^praice\.php$ /praice.html [R=301,L]
RewriteRule ^prais\.php$ /praice.html [R=301,L]
RewriteRule ^o_nas\.php$ /o_nas.html [R=301,L]
RewriteRule ^contakti\.php$ /contakti.html [R=301,L]
RewriteRule ^contacti\.php$ /contakti.html [R=301,L]
RewriteRule ^news\.php$ /news.html [R=301,L]
RewriteRule ^aktciya\.php$ /aktciya.html [R=301,L]
RewriteRule ^kondicioner\.php$ /uslugi/chistka-kondicionera.html [R=301,L]
RewriteRule ^konditioner\.php$ /uslugi/chistka-kondicionera.html [R=301,L]
RewriteRule ^Vacansii\.php$ /o_nas.html [R=301,L]
RewriteRule ^stati\.php$ /news.html [R=301,L]
